@article{xu2026nightmuseum,
  title       = {Night at the Museum: A Scalable Framework for Text-Driven Mesh Motion Generation},
  author      = {Xu, Chenyang and Li, Haoran and Jiang, Zeyu and He, Guangzhao and Zhang, Shichen and Zhang, Juexiao and Li‡, Sihang and Feng‡, Chen and Zhang‡, Jing},
  year        = {2026},
  abbr        = {In Submission},
  abstract    = {Animating static meshes into realistic motion conditioned on text prompts remains a fundamental yet challenging problem. We propose a semantic-aware and scalable framework for text-driven mesh motion generation. We introduce AniMuse Gaussian Nodes, a novel rigging representation that unifies geometric control with semantic information. The framework requires no manual labelling, making it naturally scalable. A large-scale animal mesh motion dataset is curated to demonstrate scalability.},
  website     = {https://chenyang-joe.github.io/AniMusePage/},
  annotation  = {‡ Corresponding authors},
  selected    = {true}
}

@article{jiang2026crag,
  title       = {CRAG: Can 3D Generative Models Help 3D Assembly?},
  author      = {Jiang*, Zeyu and Li*, Sihang and Tan†, Siqi and Xu†, Chenyang and Zhang, Juexiao and Galway-Witham, Julia and Wang, Xue and Williams, Scott A and Iovita, Radu and Feng‡, Chen and Zhang‡, Jing},
  year        = {2026},
  abbr        = {Under Review},
  abstract    = {We reformulate 3D assembly as a joint problem combining assembly and generation. These two processes are mutually reinforcing: assembly provides part-level structural priors for generation, while generation injects holistic shape context that resolves ambiguities in assembly. We design a physically based simulation pipeline to model the fossilization process of bones and implement FractureBEM for modeling brittle fracture behavior.},
  arxiv       = {2602.22629},
  preview     = {crag.jpg},
  annotation  = {* Equal contribution<br>† Equal contribution<br>‡ Corresponding authors},
  selected    = {true}
}

@article{li2025garf,
  title       = {GARF: Learning Generalizable 3D Reassembly for Real-World Fractures},
  author      = {Li*, Sihang and Jiang*, Zeyu and Chen†, Grace and Xu†, Chenyang and Tan, Siqi and Wang, Xue and Fang, Irving and Zyskowski, Kristof and McPherron, Shannon P and Iovita, Radu and Feng‡, Chen and Zhang‡, Jing},
  year        = {2025},
  abbr        = {ICCV 2025},
  abstract    = {We present GARF, a generalizable flow matching-based 3D reassembly method trained on 1.9 Million fractures, enabling precise real-world fragment pose alignment. Our method generalizes across diverse fracture patterns without category-specific priors.},
  arxiv       = {2504.05400},
  code        = {https://github.com/ai4ce/GARF},
  website     = {https://ai4ce.github.io/GARF/},
  preview     = {garf.jpg},
  annotation  = {* Equal contribution<br>† Equal contribution<br>‡ Corresponding authors},
  selected    = {true}
}
